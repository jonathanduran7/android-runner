{
  "name": "android-runner",
  "displayName": "android-runner",
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.105.1"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "androidRunner",
          "title": "Android Runner",
          "icon": "resources/android.svg"
        }
      ]
    },
    "views": {
      "androidRunner": [
        {
          "id": "androidRunnerView",
          "name": "Android"
        },
        {
          "id": "androidNetworkView",
          "name": "Network"
        }
      ]
    },
    "commands": [
      { "command": "androidRunner.runAndLogs", "title": "Android: Run & Stream Logs" },
      { "command": "androidRunner.runStaging", "title": "Android: Run Staging" },
      { "command": "androidRunner.reinstallLast", "title": "Android: Reinstall Last APK" },
      { "command": "androidRunner.logs", "title": "Android: Logs" },
      { "command": "androidRunner.killEmulator", "title": "Android: Kill Emulator" },
      { "command": "androidRunner.stopLogs", "title": "Android: Stop Logs" },
      { "command": "androidRunner.focusLogs", "title": "Android: Focus Logs" },
      { "command": "androidRunner.refreshView", "title": "Android Runner: Refresh" },
      { "command": "androidRunner.clearNetworkLog", "title": "Android: Clear Network Log", "icon": "$(clear-all)" },
      { "command": "androidRunner.showNetworkTransaction", "title": "Android: Show Network Transaction" }
    ],
    "menus": {
      "view/title": [
        {
          "command": "androidRunner.clearNetworkLog",
          "when": "view == androidNetworkView",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Android Runner",
      "properties": {
        "androidRunner.sdkPath": {
          "type": "string",
          "default": "",
          "description": "Path to Android SDK (e.g. ~/Library/Android/sdk). Leave empty to use ANDROID_HOME/ANDROID_SDK_ROOT or auto-detect."
        },
        "androidRunner.defaultAvd": {
          "type": "string",
          "default": "Pixel_9_API34",
          "description": "Default AVD name to use when starting emulator"
        },
        "androidRunner.keepEmulator": {
          "type": "boolean",
          "default": false,
          "description": "Keep emulator running when stopping logs (do not kill on exit)"
        },
        "androidRunner.taskAppIds": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "default": {
            "installStaging": "com.altwo.wallet.staging",
            "installDebug": "com.altwo.wallet.debug"
          },
          "description": "Map Gradle install task suffix to applicationId (e.g. installStaging -> com.example.staging)"
        },
        "androidRunner.notifications": {
          "type": "boolean",
          "default": true,
          "description": "Show notifications for emulator ready, install complete, app launched, logs streaming, etc."
        }
      }
    }
  },
  "activationEvents": [
    "onView:androidRunnerView",
    "onView:androidNetworkView",
    "onCommand:androidRunner.runAndLogs",
    "onCommand:androidRunner.runStaging",
    "onCommand:androidRunner.reinstallLast",
    "onCommand:androidRunner.logs",
    "onCommand:androidRunner.killEmulator",
    "onCommand:androidRunner.stopLogs",
    "onCommand:androidRunner.focusLogs",
    "onCommand:androidRunner.refreshView"
  ],
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.105.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}

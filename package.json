{
  "name": "android-runner",
  "displayName": "Android Runner",
  "description": "Build, install and debug Android apps from VS Code: launch emulators, install APKs via Gradle, stream filtered logcat, and inspect OkHttp network traffic.",
  "version": "0.0.4",
  "publisher": "jonathan-duran-7",
  "repository": {
    "type": "git",
    "url": "https://github.com/jonathanduran7/android-runner.git"
  },
  "engines": {
    "vscode": "^1.105.1"
  },
  "categories": [
    "Other"
  ],
  "icon": "resources/logo.png",
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "androidRunner",
          "title": "Android Runner",
          "icon": "resources/android.svg"
        }
      ]
    },
    "views": {
      "androidRunner": [
        {
          "id": "androidRunnerView",
          "name": "Android"
        },
        {
          "id": "androidNetworkView",
          "name": "Network"
        }
      ]
    },
    "commands": [
      {
        "command": "androidRunner.runAndLogs",
        "category": "Android",
        "title": "Run & Stream Logs",
        "icon": "$(play)"
      },
      {
        "command": "androidRunner.runStaging",
        "category": "Android",
        "title": "Run Staging",
        "icon": "$(rocket)"
      },
      {
        "command": "androidRunner.reinstallLast",
        "category": "Android",
        "title": "Reinstall Last APK",
        "icon": "$(sync)"
      },
      {
        "command": "androidRunner.logs",
        "category": "Android",
        "title": "Logs",
        "icon": "$(output)"
      },
      {
        "command": "androidRunner.stopLogs",
        "category": "Android",
        "title": "Stop Logs",
        "icon": "$(debug-stop)"
      },
      {
        "command": "androidRunner.killEmulator",
        "category": "Android",
        "title": "Kill Emulator",
        "icon": "$(trash)"
      },
      {
        "command": "androidRunner.focusLogs",
        "category": "Android",
        "title": "Focus Logs",
        "icon": "$(output-view-icon)"
      },
      {
        "command": "androidRunner.refreshView",
        "category": "Android Runner",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "androidRunner.clearNetworkLog",
        "category": "Android",
        "title": "Clear Network Log",
        "icon": "$(clear-all)"
      },
      {
        "command": "androidRunner.showNetworkTransaction",
        "category": "Android",
        "title": "Show Network Transaction",
        "icon": "$(search)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "androidRunner.clearNetworkLog",
          "when": "view == androidNetworkView",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Android Runner",
      "properties": {
        "androidRunner.sdkPath": {
          "type": "string",
          "default": "",
          "description": "Path to Android SDK (e.g. ~/Library/Android/sdk). Leave empty to use ANDROID_HOME/ANDROID_SDK_ROOT or auto-detect."
        },
        "androidRunner.defaultAvd": {
          "type": "string",
          "default": "Pixel_9_API34",
          "description": "Default AVD name to use when starting emulator"
        },
        "androidRunner.keepEmulator": {
          "type": "boolean",
          "default": false,
          "description": "Keep emulator running when stopping logs (do not kill on exit)"
        },
        "androidRunner.taskAppIds": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "default": {},
          "description": "Override applicationId per Gradle install task suffix (e.g. {\"installStaging\": \"com.example.app.staging\"}). If empty, the extension auto-detects the applicationId from app/build.gradle."
        },
        "androidRunner.notifications": {
          "type": "boolean",
          "default": true,
          "description": "Show notifications for emulator ready, install complete, app launched, logs streaming, etc."
        }
      }
    }
  },
  "activationEvents": [
    "onView:androidRunnerView",
    "onView:androidNetworkView",
    "onCommand:androidRunner.runAndLogs",
    "onCommand:androidRunner.runStaging",
    "onCommand:androidRunner.reinstallLast",
    "onCommand:androidRunner.logs",
    "onCommand:androidRunner.killEmulator",
    "onCommand:androidRunner.stopLogs",
    "onCommand:androidRunner.focusLogs",
    "onCommand:androidRunner.refreshView"
  ],
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.105.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
